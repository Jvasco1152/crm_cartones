generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cliente {
  id               String        @id @default(cuid())
  empresa          String
  nit              String?
  ciudad           String        @default("Bogotá")
  segmento         String        @default("Industrial")
  contacto         String
  cargo            String?
  telefono         String?
  celular          String?
  email            String?
  direccion        String?
  estado           String        @default("Prospecto")
  volumenMensual   Float?
  productosInteres String?
  notas            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  oportunidades    Oportunidad[]
  actividades      Actividad[]
  tareas           Tarea[]
}

model Oportunidad {
  id               String    @id @default(cuid())
  titulo           String
  valor            Float     @default(0)
  etapa            String    @default("Prospección")
  probabilidad     Int       @default(10)
  fechaCierre      DateTime?
  producto         String?
  descripcion      String?
  notasSeguimiento String?
  clienteId        String
  cliente          Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Actividad {
  id            String    @id @default(cuid())
  tipo          String    @default("Llamada")
  fecha         DateTime  @default(now())
  descripcion   String
  resultado     String?
  proximaAccion String?
  fechaProxima  DateTime?
  clienteId     String
  cliente       Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
}

model Tarea {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  fechaLimite DateTime
  prioridad   String    @default("Media")
  completada  Boolean   @default(false)
  tipo        String    @default("Seguimiento")
  clienteId   String?
  cliente     Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
